# Copy this file to `.env.local` for local development.
# Never commit `.env.local` — `.gitignore` already excludes `.env*`.

# Public (safe to expose to the client bundle)
NEXT_PUBLIC_APP_URL=https://dopl-app.vercel.app
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER expose to the client
SUPABASE_SERVICE_ROLE_KEY=

# SnapTrade (broker connect — read-only positions)
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=

# SnapTrade sandbox (optional — dev/test broker chain without real creds).
# Set SNAPTRADE_SANDBOX=true AND both sandbox credentials to route the
# SDK to the sandbox brokerage catalog. Falls back to prod keys if any
# sandbox piece is missing so dev setup failures stay loud.
SNAPTRADE_SANDBOX=
SNAPTRADE_SANDBOX_CLIENT_ID=
SNAPTRADE_SANDBOX_CONSUMER_KEY=
# Optional: override the SnapTrade API base URL. Prod + sandbox share
# the same endpoint today (https://api.snaptrade.com/api/v1); this is
# an escape hatch in case SnapTrade ever ships a distinct sandbox URL.
SNAPTRADE_BASE_URL=

# Salt Edge (bank connect — payout flow)
SALTEDGE_APP_ID=
SALTEDGE_SECRET=

# Stripe (Stripe Connect + subscription payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Admin-only — gates /api/migrate. Generate with:
#   openssl rand -hex 32
MIGRATION_ADMIN_TOKEN=

# Web Push (VAPID keypair). Generate with:
#   npx web-push generate-vapid-keys
# Public key is safe to expose to the client; private key is server-only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Finnhub (market data — ticker search, quotes, market status). Free tier:
# 60 calls/min globally. Get a key at finnhub.io. Server-only.
FINNHUB_API_KEY=
