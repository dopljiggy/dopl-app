# Copy this file to `.env.local` for local development.
# Never commit `.env.local` — `.gitignore` already excludes `.env*`.

# Public (safe to expose to the client bundle)
NEXT_PUBLIC_APP_URL=https://dopl-app.vercel.app
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER expose to the client
SUPABASE_SERVICE_ROLE_KEY=

# SnapTrade (broker connect — read-only positions)
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=

# Salt Edge (bank connect — payout flow)
SALTEDGE_APP_ID=
SALTEDGE_SECRET=

# Stripe (Stripe Connect + subscription payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
